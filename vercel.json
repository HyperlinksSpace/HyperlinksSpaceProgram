{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run db:migrate && npx expo export -p web --output-dir .vercel/output/static && npx tsx scripts/set-webhook.ts",
  "outputDirectory": ".vercel/output/static",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/telegram/messages/status",
      "destination": "/api/telegram-messages-status"
    },
    {
      "source": "/api/telegram/messages/connect",
      "destination": "/api/telegram-messages-connect"
    },
    {
      "source": "/api/telegram/messages/disconnect",
      "destination": "/api/telegram-messages-disconnect"
    },
    {
      "source": "/api/telegram/messages/chats",
      "destination": "/api/telegram-messages-chats"
    },
    {
      "source": "/api/telegram/messages/chats/stream",
      "destination": "/api/telegram-messages-chats-stream"
    },
    {
      "source": "/api/telegram/messages/send",
      "destination": "/api/telegram-messages-send"
    },
    {
      "source": "/api/telegram/messages/edit",
      "destination": "/api/telegram-messages-edit"
    },
    {
      "source": "/api/telegram/messages/resolve-chat",
      "destination": "/api/telegram-messages-resolve-chat"
    },
    {
      "source": "/api/telegram/mtproto/connect/start",
      "destination": "/api/telegram-mtproto-connect-start"
    },
    {
      "source": "/api/telegram/mtproto/connect/status",
      "destination": "/api/telegram-mtproto-connect-status"
    },
    {
      "source": "/api/telegram/mtproto/connect/password",
      "destination": "/api/telegram-mtproto-connect-password"
    },
    {
      "source": "/api/telegram/mtproto/connect/phone",
      "destination": "/api/telegram-mtproto-connect-phone"
    },
    {
      "source": "/api/telegram/mtproto/connect/code",
      "destination": "/api/telegram-mtproto-connect-code"
    },
    {
      "source": "/api/telegram/mtproto/connect/resend-code",
      "destination": "/api/telegram-mtproto-connect-resend-code"
    },
    {
      "source": "/api/kms/ping",
      "destination": "/api/wallet-envelope-ping"
    },
    {
      "source": "/api/kms-ping",
      "destination": "/api/wallet-envelope-ping"
    },
    {
      "source": "/api/kmsping",
      "destination": "/api/wallet-envelope-ping"
    },
    {
      "source": "/api/kmsprobe",
      "destination": "/api/wallet-envelope-probe"
    },
    {
      "source": "/api/kms-roundtrip",
      "destination": "/api/wallet-envelope-roundtrip"
    },
    {
      "source": "/((?!api/|_expo/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 60
    },
    "api/wallet/[slug].ts": {
      "maxDuration": 60
    },
    "api/auth/session.ts": {
      "maxDuration": 30
    }
  }
}
