# TDLib gateway for Railway (linux/amd64). Build context: repo root.
FROM node:22-bookworm-slim

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY deploy/railway/package.json deploy/railway/package-lock.json ./
RUN npm ci

COPY scripts/load-env.ts scripts/run-tdlib-gateway.ts scripts/
COPY telegram/tdlib ./telegram/tdlib
COPY database/start.ts database/telegramMessages.ts database/telegramMtproto.ts database/

ENV NODE_ENV=production
ENV TDLIB_GATEWAY_HOST=0.0.0.0
ENV TDLIB_DB_ROOT=/data/tdlib

# Railway injects PORT; getGatewayPort() falls back to it when TDLIB_GATEWAY_PORT is unset.
EXPOSE 8787

CMD ["npx", "tsx", "scripts/run-tdlib-gateway.ts"]
